# =========================================================
# Python
# =========================================================
__pycache__/
*.py[cod]
*.pyo
*.pyd
*.so
*.egg
*.egg-info/
dist/
build/
pip-wheel-metadata/

# Virtual environments
.venv/
venv/
env/
ENV/

# Jupyter
.ipynb_checkpoints/

# =========================================================
# Local IDE / OS
# =========================================================
.vscode/
.DS_Store
Thumbs.db

# =========================================================
# Logs / runtime files
# =========================================================
*.log
logs/
tmp/
temp/
*.tmp

# =========================================================
# Secrets / credentials
# =========================================================
.env
.env.*
secrets/
credentials/
*.pem
*.key
*.pfx
*.p12
*.crt
*.cer
*.jks

# =========================================================
# SQL Server / database artifacts
# =========================================================
*.bak
*.bacpac
*.dacpac
*.mdf
*.ldf
*.ndf
*.trn

# =========================================================
# Docker / local infrastructure
# =========================================================
docker-data/
*.tar

# =========================================================
# Terraform / cloud state
# =========================================================
*.tfstate
*.tfstate.*
.terraform/
.terraform.lock.hcl

# =========================================================
# Airflow local runtime
# =========================================================
airflow/logs/
airflow/airflow.db
airflow/webserver_config.py

# =========================================================
# Tableau local artifacts
# Keep screenshots and documentation, ignore heavy/temp extracts
# =========================================================
*.hyper
*.tde
*.twbx~
*.twbr
Tableau Temp/

# =========================================================
# ML model artifacts
# Keep source code, ignore trained binary models
# =========================================================
*.pkl
*.joblib
*.onnx
ml/models/*.pkl
ml/models/*.joblib
ml/models/*.onnx

# =========================================================
# Data governance: ignore sensitive/raw/private data
# Keep curated synthetic/demo datasets only
# =========================================================
data/raw/private/
data/raw/phi/
data/raw/prod/
data/raw/client/
data/temp/
data/output/
data/interim/

# Ignore accidental production-style data drops
*claims_export*
*member_export*
*provider_export*
*phi*
*PHI*
*prod*
*client_extract*

# =========================================================
# Node / frontend
# =========================================================
node_modules/

# =========================================================
# Coverage / testing
# =========================================================
.coverage
htmlcov/
.pytest_cache/

# =========================================================
# Keep public demo assets
# =========================================================
!docs/images/
!docs/images/*.png
!docs/images/*.jpg
!docs/images/*.jpeg

!tableau/data/
!tableau/data/*.csv

!data/synthetic/
!data/synthetic/*.csv

!data/gold/
!data/gold/*.csv

!data/silver/
!data/silver/*.csv
